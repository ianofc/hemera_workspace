# zios/main.py

import os
import logging
import hashlib
import google.generativeai as genai
from fastapi import FastAPI, Query, HTTPException, Request
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field
from typing import List, Optional
from datetime import datetime
from dotenv import load_dotenv

load_dotenv()

# --- CONFIGURAÇÃO DE TELEMETRIA PENTAIA ---
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger("ZIOS_HEIMDALL_CORE")

# --- INTEGRAÇÃO NEURAL (GEMINI) ---
genai.configure(api_key=os.getenv("GEMINI_API_KEY"))
gemini = genai.GenerativeModel('gemini-1.5-flash')

app = FastAPI(
    title="ZIOS - Proactive Intelligence & Sovereign Shield",
    description="Núcleo de Inteligência Proativa e Proteção de Borda Heimdall.",
    version="2.5.0"
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

# --- SCHEMAS DE ALTA FIDELIDADE ---

class HeimdallTelemetry(BaseModel):
    risk_score: float = Field(..., description="Índice de ameaça calculado de 0.0 a 1.0")
    analysis_latency: str
    signature: str = Field(..., description="Assinatura SHA-256 da verificação")

class HeimdallCheckResponse(BaseModel):
    status: str
    shield_level: str
    client_ip: str
    threat_detected: bool
    intelligence_report: str = Field(..., description="Sintese de segurança gerada via Gemini")
    recommendations: List[str]
    telemetry: HeimdallTelemetry
    timestamp: str

# --- LÓGICA DE ESCUDO HEIMDALL ---

class HeimdallEngine:
    """
    Motor de Defesa do Século XXII.
    Analisa padrões de tráfego e gera respostas neurais.
    """
    
    @staticmethod
    async def generate_security_insight(ip: str, risk_score: float) -> str:
        """Invoca o Gemini para criar um relatório de inteligência dinâmico."""
        if risk_score < 0.3:
            return "Nó de rede operando em harmonia. Protocolos de confiança validados."
        
        prompt = (
            f"Aja como o sistema de segurança IA Heimdall. O IP {ip} apresentou um score de risco de {risk_score*100}%. "
            "Gere uma análise técnica de uma frase alertando sobre possíveis vetores de intrusão e confirmando o isolamento."
        )
        try:
            response = gemini.generate_content(prompt)
            return response.text.strip()
        except:
            return "Anomalia detectada. Escudo de integridade elevado para Nível Máximo."

    @staticmethod
    def calculate_risk(ip: str) -> float:
        """
        Algoritmo de Reputação Estocástica.
        Simula a checagem em bancos de dados globais (GreyNoise, AlienVault).
        """
        # Exemplo de lógica robusta: IPs de redes locais conhecidas têm risco zero
        if ip.startswith(("127.", "192.168.", "172.18.")):
            return 0.01
        
        # Simulação de detecção de anomalia baseada em entropia do IP
        hash_ip = hashlib.md5(ip.encode()).hexdigest()
        if any(char in hash_ip[:3] for char in ['a', '0', 'f']):
            return 0.78  # Simula IP flagado em botnet
        
        return 0.12

# --- ENDPOINTS ---

@app.get("/", tags=["Pulse"])
async def root():
    return {
        "status": "ZIOS OMEGA ACTIVE",
        "shield": "HEIMDALL OPERATIONAL",
        "epoch": datetime.now().timestamp()
    }

@app.get("/v1/proactive/heimdall/check", response_model=HeimdallCheckResponse, tags=["Security"])
async def heimdall_security_check(
    request: Request,
    ip: str = Query(..., description="Endereço IP para varredura de integridade")
):
    """
    HEIMDALL SPECTRAL SCAN:
    Executa varredura profunda de reputação de IP, calcula score de risco
    e gera contramedidas inteligentes via Google Gemini.
    """
    start_time = datetime.now()
    
    # 1. Cálculo de Risco
    risk_score = HeimdallEngine.calculate_risk(ip)
    threat_detected = risk_score > 0.5
    
    # 2. Ressonância Neural (Gemini)
    intelligence_report = await HeimdallEngine.generate_security_insight(ip, risk_score)
    
    # 3. Definição de Recomendações (Padrão Corporativo)
    recs = ["Manter monitoramento de sessão"]
    if threat_detected:
        recs = [
            "Acionar MFA obrigatório",
            "Criptografar túnel de transporte (TLS 1.3)",
            "Isolar pacotes de metadados suspeitos"
        ]
    
    # 4. Assinatura de Integridade
    latency = f"{(datetime.now() - start_time).total_seconds() * 1000:.2f}ms"
    sig_payload = f"{ip}-{risk_score}-{latency}"
    signature = hashlib.sha256(sig_payload.encode()).hexdigest()

    return HeimdallCheckResponse(
        status="PROTECTED" if not threat_detected else "WARNING",
        shield_level="OPTIMAL" if risk_score < 0.2 else "ELEVATED",
        client_ip=ip,
        threat_detected=threat_detected,
        intelligence_report=intelligence_report,
        recommendations=recs,
        telemetry=HeimdallTelemetry(
            risk_score=risk_score,
            analysis_latency=latency,
            signature=signature
        ),
        timestamp=datetime.now().isoformat()
    )

if __name__ == "__main__":
    import uvicorn
    # Zios roda na porta 8002 conforme topologia PentaIA
    uvicorn.run(app, host="0.0.0.0", port=8002)